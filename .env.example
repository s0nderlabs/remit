# remit server (packages/server)
REMIT_MASTER_KEY=          # required: 64 hex chars (32 bytes); encrypts agent keys + card secrets at rest
REMIT_ADMIN_TOKEN=         # required: bearer token protecting the management API (/api/*)
PORT=4070
REMIT_DB_PATH=.dev/remit.sqlite
REMIT_RPC_URL=https://mainnet.base.org
REMIT_PUBLIC_MCP_BASE=     # public origin used when rendering card URLs, e.g. https://api.example.com
REMIT_CORS_ORIGINS=        # comma-separated allowed origins for the API, e.g. https://app.example.com
REMIT_DEV_USER_PK=         # dev only: server-custodied user key for the server-signed issuance lane
REMIT_FACILITATOR_BASE=    # x402 facilitator base URL (defaults to this server)
REMIT_SELLER_PAYTO=        # payout address for the built-in demo seller
REMIT_PAID_FETCH_ALLOW_LOCAL=  # set to 1 to let paid_fetch hit local/private hosts (dev only)
REMIT_STRIPE_WEBHOOK_SECRET=   # Stripe real-time auth webhook signing secret (test mode)

# remit dashboard (packages/dashboard)
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=
NEXT_PUBLIC_REMIT_API=http://localhost:4070/api
NEXT_PUBLIC_REMIT_ADMIN_TOKEN=  # dev posture: dashboard talks to the management API with this token
NEXT_PUBLIC_BASE_RPC=https://mainnet.base.org
