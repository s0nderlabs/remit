# remit server (packages/server)
REMIT_MASTER_KEY=          # required: 64 hex chars (32 bytes); encrypts agent keys + card secrets at rest
REMIT_ADMIN_TOKEN=         # ops lane: bearer token with FULL access to the management API (/api/*) — server-side curl/scripts only
REMIT_PRIVY_APP_ID=        # dashboard lane: enables per-user auth (Privy access tokens verified against this app's JWKS)
PORT=4070
REMIT_DB_PATH=.dev/remit.sqlite
REMIT_RPC_URL=https://mainnet.base.org
REMIT_PUBLIC_MCP_BASE=     # public origin used when rendering card URLs, e.g. https://api.example.com (also arms the MCP Host allowlist; unset = localhost)
REMIT_ALLOWED_HOSTS=       # extra Host headers accepted on /mcp + /c/<secret>/mcp (comma-separated)
REMIT_CORS_ORIGINS=        # comma-separated allowed origins for the API, e.g. https://app.example.com
REMIT_DEV_USER_PK=         # dev only: server-custodied user key for the server-signed issuance lane
REMIT_FACILITATOR_BASE=    # x402 facilitator base URL (defaults to this server)
REMIT_SELLER_PAYTO=        # payout address for the built-in demo seller
REMIT_PAID_FETCH_ALLOW_LOCAL=  # set to 1 to let paid_fetch hit local/private hosts (dev only)
REMIT_STRIPE_WEBHOOK_SECRET=   # Stripe real-time auth webhook signing secret (test mode); unset = fiat leg disabled (503)
# Optional tuning (defaults apply when unset; uncomment to override):
#REMIT_RECONCILE_INTERVAL_MS=300000   # stuck-pending-charge reconcile sweep interval, ms (0 disables)
#REMIT_MCP_RATE_LIMIT=240             # per-card MCP request ceiling per minute
#REMIT_MCP_BAD_SECRET_LIMIT=30        # per-IP bad-secret attempt ceiling per minute

# remit dashboard (packages/dashboard)
# The dashboard authenticates as the USER: every API call carries the Privy session
# token, verified server-side. No admin token ever reaches the browser.
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=
NEXT_PUBLIC_REMIT_API=http://localhost:4070/api
NEXT_PUBLIC_BASE_RPC=https://mainnet.base.org
